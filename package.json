{
  "name": "@sap/mdk-mcp-server",
  "mcpName": "io.github.SAP/mdk-mcp-server",
  "version": "0.4.0",
  "license": "Apache-2.0",
  "description": "Model Context Protocol (MCP) server for AI-assisted development of MDK applications.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SAP/mdk-mcp-server.git"
  },
  "author": "SAP SE (https://www.sap.com)",
  "homepage": "https://help.sap.com/docs/MDK",
  "bin": {
    "mdk-mcp": "./build/start.js"
  },
  "files": [
    "build/",
    "res/",
    "images/",
    "scripts/",
    "config/",
    ".claude-plugin/",
    ".mcp.json",
    "manifest.json",
    ".npmrc",
    ".env.example"
  ],
  "scripts": {
    "audit:signatures": "npm audit signatures",
    "build": "npm run audit:signatures && tsc && node -e \"require('fs').chmodSync('build/index.js', '755')\" && node -e \"require('fs').cpSync('src/lib', 'build/lib', {recursive: true})\" && node -e \"require('fs').cpSync('src/start.js', 'build/start.js')\"",
    "build:no-audit": "tsc && node -e \"require('fs').chmodSync('build/index.js', '755')\" && node -e \"require('fs').cpSync('src/lib', 'build/lib', {recursive: true})\" && node -e \"require('fs').cpSync('src/start.js', 'build/start.js')\"",
    "postinstall": "node scripts/cleanup-onnx-binaries.js",
    "test": "node --test --test-concurrency=1 src/tests/*.test.js",
    "lint": "eslint \"src/**/*.ts\" --ignore-pattern \"src/**/*.d.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --ignore-pattern \"src/**/*.d.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "lint:all": "npm run lint && npm run format:check",
    "fix:all": "npm run lint:fix && npm run format",
    "start": "npx -y supergateway --port 9881 --stdio \"node ./build/start.js\"",
    "ingest": "npm run build && node build/ingest-github-knowledge.js",
    "ingest:fresh": "npm run build && node build/ingest-github-knowledge.js --no-cache",
    "ingest:no-build": "node build/ingest-github-knowledge.js",
    "ingest:no-build:fresh": "node build/ingest-github-knowledge.js --no-cache"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@modelcontextprotocol/sdk": "^1.25.3",
    "@octokit/rest": "^21.0.2",
    "@sap-devx/app-studio-toolkit-types": "^2.11.0",
    "@sap-ux/btp-utils": "1.1.5",
    "@sap-ux/feature-toggle": "0.3.4",
    "@sap-ux/telemetry": "^1.0.18",
    "@sap/artifact-management": "^1.53.1",
    "@sap/artifact-management-base": "^1.53.1",
    "@sap/generator-mdk": "1.1.1",
    "@sap/mdk-tools": "^1.16.0",
    "axios": "^1.18.1",
    "dotenv": "^17.2.3",
    "i18next": "25.3.0",
    "os-name": "4.0.1",
    "xml2js": "^0.6.2",
    "yo": "^4.3.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.11.24",
    "@types/xml2js": "^0.4.14",
    "@typescript-eslint/eslint-plugin": "^8.44.0",
    "@typescript-eslint/parser": "^8.44.0",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^4.2.5",
    "external-editor": "^3.1.0",
    "prettier": "^2.8.8",
    "tmp": "^0.2.7",
    "ts-jest": "^29.2.5",
    "typescript": "^5.3.3"
  },
  "overrides": {
    "ajv@8.18.0": "8.20.0",
    "postcss": "^8.4.31",
    "glob": "^12.0.0",
    "@octokit/plugin-paginate-rest": "^11.3.5",
    "@octokit/request": "^9.1.3",
    "@octokit/request-error": "^6.1.5",
    "form-data": "^4.0.1",
    "tough-cookie": "^5.0.0",
    "qs": "6.15.3",
    "diff": "^8.0.3",
    "tar": "^7.5.11",
    "fast-xml-parser": "^5.3.8",
    "hono": "^4.12.4",
    "@hono/node-server": "^2.0.0",
    "cacache": "^19.0.1",
    "@npmcli/map-workspaces": "^4.0.2",
    "@npmcli/arborist": "^8.0.0",
    "handlebars": "^4.7.9",
    "locutus": "^3.0.34",
    "protobufjs": "^8.2.0",
    "rimraf": "^6.0.0",
    "uuid": "^11.0.4",
    "@xmldom/xmldom": "^0.9.5",
    "consolidate": "^1.0.4",
    "comment-json": "^5.0.0",
    "pacote": "^20.0.1",
    "tmp": "^0.2.7",
    "ws": "^8.21.0",
    "metro-react-native-babel-preset": "npm:@react-native/babel-preset@^0.85.3",
    "@babel/plugin-proposal-optional-catch-binding": "npm:@babel/plugin-transform-optional-catch-binding@^7.24.7",
    "@babel/plugin-proposal-nullish-coalescing-operator": "npm:@babel/plugin-transform-nullish-coalescing-operator@^7.24.7",
    "@babel/plugin-proposal-class-properties": "npm:@babel/plugin-transform-class-properties@^7.24.7",
    "@babel/plugin-proposal-optional-chaining": "npm:@babel/plugin-transform-optional-chaining@^7.24.7",
    "@babel/plugin-proposal-async-generator-functions": "npm:@babel/plugin-transform-async-generator-functions@^7.24.7",
    "@babel/plugin-proposal-object-rest-spread": "npm:@babel/plugin-transform-object-rest-spread@^7.24.7",
    "@opentelemetry/core": "^2.8.0",
    "axios": "^1.18.1",
    "lodash": "^4.17.24",
    "minimatch": "^10.2.5",
    "semver-regex": "^3.1.4",
    "serialize-javascript": "^7.0.5",
    "http-cache-semantics": "^4.1.1",
    "trim-newlines": "^3.0.1",
    "yargs-parser": "^20.2.9",
    "adm-zip": "^0.6.0",
    "@sigstore/core": "^4.0.1",
    "sigstore": "^5.0.0",
    "got": "^11.8.6",
    "js-yaml": "^4.1.0"
  },
  "mdkConfig": {
    "schemaVersion": "26.6"
  }
}
