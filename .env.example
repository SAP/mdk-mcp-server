# MDK MCP Server Environment Variables

# Application Insights Instrumentation Key
# Get your key from Azure Portal > Application Insights > Overview > Instrumentation Key
# Copy this file to .env and replace the placeholder with your actual key
INSTRUMENTATION_KEY=your-instrumentation-key-here

# GitHub Configuration (Optional - for fetching additional knowledge sources)
# Required for accessing private repositories or to avoid rate limits
GITHUB_TOKEN=your-github-token-here
